model ShoppingCommission {
  id             String   @id @default(cuid())
  workspaceId    String
  shoppingSaleId String?
  centerId       String

  periodYear  Int
  periodMonth Int

  // 정책 1-A: VAT round 통일 (기존 ERP에서는 trunc였음)
  commissionWon   Int
  vatWon          Int @default(0)
  totalWithVatWon Int
  // 이 매출에 실제 적용된 수수료율(%). 통계·감사용. null이면 사용자가 commissionWon을 직접 입력한 경우.
