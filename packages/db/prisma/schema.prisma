// BT TOUR SaaS — 스키마 1차안 (Phase 0)
//
// 이 파일은 멀티테넌시 + 인증 + 결제 + AI 크레딧의 골격만 담는다.
// 도메인 모델(Team, Schedule, Guide, Hotel 등)은 Codex의 docs/DOMAIN_MAPPING.md 분석 결과를
// 받은 뒤 Phase 2에서 추가한다. 추가 시 모든 테이블에는 `workspaceId` 필수.

generator client {
  provider = "prisma-client-js"
  // 표준 위치(node_modules/.prisma/client) 사용 — Vercel/Next.js가 자동 trace.
  // 이전엔 모노레포 hoisting EPERM 우려로 custom output 사용했으나
  // Vercel deploy에서 .so 엔진 누락 문제로 표준 위치로 복귀.
  // dev 환경 EPERM은 dev 서버 종료 후 generate 운영 룰로 회피.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// 인증 & 사용자
// NextAuth v5 (Auth.js) Prisma adapter 표준 모델을 따른다.
// ─────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  locale        Locale    @default(KO)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  memberships Membership[]
  invitesSent Invitation[] @relation("InvitedBy")
  receiptOcrJobs ReceiptOcrJob[]
  settlementPdfJobs SettlementPdfJob[]
  monthlyInsights MonthlyInsight[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────────────────────────────────
// 멀티테넌시: Workspace + Membership + Invitation
// ─────────────────────────────────────────────────────────────────────────

model Workspace {
  id        String   @id @default(cuid())
  slug      String   @unique // URL 식별자: /w/[slug]
  name      String
  logoUrl   String?
  // 사업자 정보 (도면 footer 영역)
  bizName   String?
  bizNumber String?
  bizCeo    String?
  bizPhone  String?
  bizEmail  String?
  bizAddr   String?

  // 워크스페이스 기본 로케일 (개별 사용자 로케일과 별개)
  defaultLocale Locale @default(KO)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  memberships  Membership[]
  invitations  Invitation[]
  subscription Subscription?
  aiCredits    AiCreditLedger[]
  auditLogs    AuditLog[]

  // Phase 2 도메인 (마스터/운영/정산/회계/분석)
  partners               Partner[]
  guides                 Guide[]
  hotels                 Hotel[]
  vehicles               Vehicle[]
  drivers                Driver[]
  shoppingCenters        ShoppingCenter[]
  tourTeams              TourTeam[]
  teamGuideAssignments   TeamGuideAssignment[]
  teamHotelStays         TeamHotelStay[]
  teamVehicleAssignments TeamVehicleAssignment[]
  guideSettlements       GuideSettlement[]
  guideSettlementPayments GuideSettlementPayment[]
  vehicleSettlements     VehicleSettlement[]
  vehicleSettlementPayments VehicleSettlementPayment[]
  shoppingSales          ShoppingSale[]
  shoppingCommissions    ShoppingCommission[]
  financeWallets         FinanceWallet[]
  financeLedgerLines     FinanceLedgerLine[]
  receivables            Receivable[]
  receivablePayments     ReceivablePayment[]
  expenses               Expense[]
  expenseAttachments     ExpenseAttachment[]
  exchangeRates          ExchangeRate[]

  // Phase 4 통합 (AI / 메시징 / 백업)
  aiSettings             WorkspaceAiSettings?
  aiProviderConfigs      WorkspaceAiProviderConfig[]
  aiJobs                 AiJob[]
  messagingSettings      WorkspaceMessagingSettings?
  backupSettings         WorkspaceBackupSettings?
  backupExports          BackupExportJob[]
  receiptOcrJobs         ReceiptOcrJob[]
  settlementPdfJobs      SettlementPdfJob[]
  monthlyInsights        MonthlyInsight[]

  @@index([deletedAt])
  @@map("workspaces")
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  VIEWER
}

enum MembershipStatus {
  PENDING // 가입 신청 후 관리자 승인 대기
  ACTIVE
  SUSPENDED
}

model Membership {
  id          String           @id @default(cuid())
  workspaceId String
  userId      String
  role        Role             @default(VIEWER)
  status      MembershipStatus @default(PENDING)
  invitedById String?
  joinedAt    DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, status])
  @@map("memberships")
}

model Invitation {
  id          String   @id @default(cuid())
  workspaceId String
  email       String
  role        Role     @default(VIEWER)
  token       String   @unique
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([workspaceId, email])
  @@map("invitations")
}

// ─────────────────────────────────────────────────────────────────────────
// 결제 & 플랜
// 도면 index.html PRICING 섹션 기준: Starter / Pro / Pro AI / Business AI
// ─────────────────────────────────────────────────────────────────────────

enum PlanCode {
  STARTER
  PRO
  PRO_AI
  BUSINESS_AI
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

model Plan {
  code            PlanCode @id
  name            String // 표기용 명칭 (한국어)
  monthlyPriceKrw Int
  // 사용량 한도 (도면 PRICING 카드 기준)
  maxUsers        Int
  maxTeamsPerMonth Int? // null = 무제한
  alimtalkQuota   Int? // null = 무제한
  aiEnabled       Boolean  @default(false)
  aiCreditIncluded Int     @default(0)
  // 셋업 비용 (1회성)
  setupFeeKrw     Int      @default(0)
  // 부가 메타
  description     String?
  highlight       Boolean  @default(false) // 도면 "가장 인기" 배지 표시 여부
  sortOrder       Int      @default(0)

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id          String             @id @default(cuid())
  workspaceId String             @unique
  planCode    PlanCode
  status      SubscriptionStatus @default(TRIALING)
  // 청구 주기
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean   @default(false)
  canceledAt         DateTime?
  trialEndsAt        DateTime?
  // 토스페이먼츠 빌링키 등 외부 식별자 (Phase 3에서 활성화)
  externalCustomerId String?
  externalBillingKey String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan      Plan      @relation(fields: [planCode], references: [code])

  @@index([status, currentPeriodEnd])
  @@map("subscriptions")
}

// ─────────────────────────────────────────────────────────────────────────
// AI 크레딧 — 도면의 "AI 크레딧 50,000 포함, 초과 5,000원/10,000 크레딧" 모델
// 입출입을 한 줄씩 기록하고 잔액은 계산으로 도출 (감사 가능성 우선).
// ─────────────────────────────────────────────────────────────────────────

enum AiCreditEntryType {
  GRANT // 플랜 포함 또는 충전
  DEBIT // 사용 차감
  REFUND // 환불 또는 보정
  EXPIRE // 만료
}

enum AiAgentKind {
  RECEIPT_OCR
  SETTLEMENT_REPORT
  RECEIVABLE_MESSAGE
  MONTHLY_INSIGHT
  SCHEDULE_CHANGE_DETECT
}

model AiCreditLedger {
  id          String            @id @default(cuid())
  workspaceId String
  type        AiCreditEntryType
  amount      Int // GRANT/REFUND는 양수, DEBIT/EXPIRE는 음수
  balanceAfter Int
  reason      String?
  agent       AiAgentKind?
  // 사용 차감의 경우 어떤 작업이었는지 추적
  refType     String? // 예: "GuideSettlement", "Receivable" 등
  refId       String?
  createdAt   DateTime          @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@map("ai_credit_ledger")
}

// ─────────────────────────────────────────────────────────────────────────
// 감사 로그 — 멀티테넌시 SaaS 필수 (RBAC 변경, 권한 승인 등 추적)
// ─────────────────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String?
  actorUserId String?
  action      String // 예: "membership.invite", "subscription.upgrade"
  targetType  String?
  targetId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────
// 다국어 — 도면 i18n KO/EN/ZH
// ─────────────────────────────────────────────────────────────────────────

enum Locale {
  KO
  EN
  ZH
}

// ═════════════════════════════════════════════════════════════════════════
// Phase 2 도메인 — Codex 03 도메인 매핑 + POLICY_DECISIONS 11개 반영
//
// 정책:
//  - 모든 테이블에 workspaceId 필수 (멀티테넌시 격리)
//  - 마스터(Guide/Hotel/Vehicle/...) 선택적 + snapshot 문자열 동시 보유 (정책 8-C)
//  - 5천원 반올림은 표시 전용 (정책 2-A) — DB는 원 단위 정수
//  - 가이드/차량 과지급 금지 (정책 3-A) — 코드 레벨 validateSettlementPayment 사용
//  - 미수금 다중통화 (정책 4-A) — currencyCode + amountMinor
//  - FinanceWallet override 컬럼 제거 (정책 6-A) — BALANCE_ADJUSTMENT ledger로 대체
//  - TourTeam.teamNo unique = workspace + year + month (정책 7-A)
//  - 외부 sync 모델 없음 (정책 5-A) — 직접 입력형만
// ═════════════════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────────────────────────────
// 마스터 (Master Data)
// ─────────────────────────────────────────────────────────────────────────

enum PartnerKind {
  AGENCY          // 인바운드 에이전트
  HOTEL_VENDOR
  VEHICLE_VENDOR
  SHOPPING_CENTER // (별도 ShoppingCenter 테이블도 있음 — 거래처 일반 view용)
  CUSTOMER
  OTHER
}

model Partner {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  kind        PartnerKind @default(AGENCY)
  contactName String?
  contactPhone String?
  contactEmail String?
  region      String?
  memo        String?
  active      Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  workspace            Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tourTeams            TourTeam[]
  guideSettlements     GuideSettlement[]
  vehicleSettlements   VehicleSettlement[]
  receivables          Receivable[]

  @@index([workspaceId, active, kind])
  @@map("partners")
}

model Guide {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  region      String?  // 가이드 활동 지역
  phone       String?
  email       String?
  language    String?  // 한국어/중국어/베트남어 등
  colorKey    String?  // 일정현황/타임라인 가이드 색상 안정 hash
  memo        String?
  active      Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  workspace          Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  guideAssignments   TeamGuideAssignment[]
  guideSettlements   GuideSettlement[]
  shoppingSales      ShoppingSale[]

  @@index([workspaceId, active])
  @@map("guides")
}

model Hotel {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  address     String?
  phone       String?
  rank        Int?     // 1~5
  region      String?
  contactName String?
  memo        String?
  active      Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  workspace  Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  hotelStays TeamHotelStay[]

  @@index([workspaceId, active])
  @@map("hotels")
}

model Vehicle {
  id          String   @id @default(cuid())
  workspaceId String
  label       String   // 차량 식별 라벨 (예: "서울 25인승 #1")
  vehicleType String?  // 25인승/45인승/세단 등
  plateNumber String?
  region      String?  // 부산/서울/제주
  vendor      String?
  memo        String?
  active      Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  workspace          Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  drivers            Driver[]
  vehicleAssignments TeamVehicleAssignment[]
  vehicleSettlements VehicleSettlement[]

  @@index([workspaceId, active])
  @@map("vehicles")
}

model Driver {
  id          String   @id @default(cuid())
  workspaceId String
  vehicleId   String?
  name        String
  phone       String?
  memo        String?
  active      Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  workspace          Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  vehicle            Vehicle?                @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  vehicleAssignments TeamVehicleAssignment[]

  @@index([workspaceId, active])
  @@map("drivers")
}

model ShoppingCenter {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  category    String?  // 인삼/적송/화장품/영지 등
  region      String?
  sortOrder   Int      @default(0)
  // 기본 수수료율 (%) — 매출 등록 시 폼에 미리 채워짐. null이면 사용자가 매번 수동 입력.
  // 정책 결정(2026-04-29): 품목/매출별 다른 수수료율 허용을 위해 항상 폼에서 override 가능.
  defaultCommissionRatePercent Float?
  memo        String?
  active      Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  workspace   Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sales       ShoppingSale[]
  commissions ShoppingCommission[]

  @@index([workspaceId, active])
  @@map("shopping_centers")
}

// ─────────────────────────────────────────────────────────────────────────
// 운영 (Operations)
// ─────────────────────────────────────────────────────────────────────────

enum TourTeamStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AssignmentStatus {
  TENTATIVE
  CONFIRMED
  CANCELLED
}

model TourTeam {
  id          String   @id @default(cuid())
  workspaceId String

  // 팀 식별 (정책 7-A: workspace + year + month + teamNo unique)
  year        Int
  month       Int
  teamNo      Int

  // 거래처 — 마스터 + snapshot 동시 (정책 8-C)
  partnerId           String?
  partnerNameSnapshot String?
  agentLabel          String?

  // 일정
  startDate   DateTime
  endDate     DateTime
  groupName   String?

  // 인원
  paxAdult    Int      @default(0)
  paxChild    Int      @default(0)
  paxInfant   Int      @default(0)
  paxTc       Int      @default(0)

  // 객실
  roomCount       Int      @default(0)
  roomComposition String?

  // 출발지/항공
  originCode  String?
  originLabel String?
  flightIn    String?
  flightOut   String?

  tourType    String?
  starRating  Int?
  status      TourTeamStatus @default(SCHEDULED)
  memo        String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  partner   Partner?  @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  guideAssignments   TeamGuideAssignment[]
  hotelStays         TeamHotelStay[]
  vehicleAssignments TeamVehicleAssignment[]
  guideSettlements   GuideSettlement[]
  vehicleSettlements VehicleSettlement[]
  shoppingSales      ShoppingSale[]
  receivables        Receivable[]
  expenses           Expense[]

  @@unique([workspaceId, year, month, teamNo])
  @@index([workspaceId, status, startDate])
  @@index([workspaceId, deletedAt])
  @@map("tour_teams")
}

model TeamGuideAssignment {
  id          String   @id @default(cuid())
  workspaceId String
  teamId      String

  guideId           String?
  guideNameSnapshot String   // 마스터 미연결시도 항상 저장

  role        String   @default("LEAD") // LEAD/SUB/INTERPRETER
  status      AssignmentStatus @default(TENTATIVE)

  startDate   DateTime?
  endDate     DateTime?
  memo        String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team      TourTeam  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  guide     Guide?    @relation(fields: [guideId], references: [id], onDelete: SetNull)

  @@index([workspaceId, teamId])
  @@index([workspaceId, guideId, startDate])
  @@map("team_guide_assignments")
}

enum HotelStaySource {
  MANUAL          // 호텔 캘린더에서 수동 입력
  SCHEDULE_AUTO   // 일정현황 팀 호텔 배정으로 자동 표시
}

model TeamHotelStay {
  id          String   @id @default(cuid())
  workspaceId String
  teamId      String

  hotelId           String?
  hotelNameSnapshot String

  checkIn       DateTime
  checkOut      DateTime
  roomCount     Int      @default(0)
  reservationNo String?

  source      HotelStaySource  @default(MANUAL)
  status      AssignmentStatus @default(TENTATIVE)
  memo        String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team      TourTeam  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  hotel     Hotel?    @relation(fields: [hotelId], references: [id], onDelete: SetNull)

  @@index([workspaceId, hotelId, checkIn])
  @@index([workspaceId, teamId])
  @@map("team_hotel_stays")
}

model TeamVehicleAssignment {
  id          String   @id @default(cuid())
  workspaceId String
  teamId      String

  vehicleId             String?
  driverId              String?
  vehicleLabelSnapshot  String

  startDate   DateTime
  endDate     DateTime

  // 차량비 (정책 1-A: VAT round) — 표시값은 packages/shared의 computeVat10/Included로 계산
  totalWon         Int @default(0)
  vatWon           Int @default(0)
  totalWithVatWon  Int @default(0)

  status      AssignmentStatus @default(TENTATIVE)
  memo        String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team              TourTeam           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  vehicle           Vehicle?           @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  driver            Driver?            @relation(fields: [driverId], references: [id], onDelete: SetNull)
  vehicleSettlement VehicleSettlement?

  @@index([workspaceId, vehicleId, startDate])
  @@index([workspaceId, teamId])
  @@map("team_vehicle_assignments")
}

// ─────────────────────────────────────────────────────────────────────────
// 정산 (Settlement)
// ─────────────────────────────────────────────────────────────────────────

enum SettlementStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

model GuideSettlement {
  id          String   @id @default(cuid())
  workspaceId String

  teamId            String?
  guideId           String?
  guideNameSnapshot String

  periodYear  Int
  periodMonth Int

  // 정책 2-A: DB는 원 단위 원값. 5천원 반올림은 표시 전용.
  totalWon    Int

  partnerId           String?
  partnerNameSnapshot String?

  status        SettlementStatus @default(DRAFT)
  confirmedAt   DateTime?
  confirmedById String?
  memo          String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team      TourTeam? @relation(fields: [teamId], references: [id], onDelete: SetNull)
  guide     Guide?    @relation(fields: [guideId], references: [id], onDelete: SetNull)
  partner   Partner?  @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  payments  GuideSettlementPayment[]

  @@index([workspaceId, periodYear, periodMonth])
  @@index([workspaceId, guideId])
  @@index([workspaceId, status])
  @@map("guide_settlements")
}

model GuideSettlementPayment {
  id           String   @id @default(cuid())
  workspaceId  String
