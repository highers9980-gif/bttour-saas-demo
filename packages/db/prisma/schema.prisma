  @@index([workspaceId, centerId, periodYear, periodMonth])
  @@map("shopping_commissions")
}

// ─────────────────────────────────────────────────────────────────────────
// 회계 (Finance)
// ─────────────────────────────────────────────────────────────────────────

enum WalletKind {
  BANK
  CARD
  FX // 외화 보유 지갑
}

enum LedgerEntryType {
  DEPOSIT
  WITHDRAWAL
  CARD_USE
  CARD_PAYMENT
  FX_OUT             // KRW → 외화
  FX_IN              // 외화 → KRW
  BALANCE_ADJUSTMENT // 정책 6-A: override 컬럼 폐지 → 보정 라인으로
  OTHER
}

model FinanceWallet {
  id          String   @id @default(cuid())
  workspaceId String

  kind         WalletKind
  name         String
  institution  String?
  numberMasked String?
  currencyCode String     @default("KRW")
  isMainKrw    Boolean    @default(false)

  // 정책 6-A: currentBalanceMinor 제거. balance = openingBalanceMinor + Σ ledger.amountMinor
  openingBalanceMinor Int @default(0)

  // 카드 한정 (kind=CARD일 때만 의미)
  billingDay     Int?
  creditLimitWon Int?

  active    Boolean  @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ledgerLines FinanceLedgerLine[]

  @@index([workspaceId, kind, active])
  @@map("finance_wallets")
}

model FinanceLedgerLine {
  id          String   @id @default(cuid())
  workspaceId String
  walletId    String

  entryType    LedgerEntryType
  lineDatetime DateTime
  amountMinor  Int            // 부호 있는 정수 (입금/+, 출금/-)
  note         String?

  // 환전 출금/입금 페어링 (FX_OUT + FX_IN을 같은 그룹으로 묶음)
  transferGroupId String?

  createdAt   DateTime @default(now())
  createdById String?

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  wallet    FinanceWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([workspaceId, walletId, lineDatetime])
  @@index([workspaceId, transferGroupId])
  @@map("finance_ledger_lines")
}

enum ReceivableStatus {
  OPEN
  PARTIALLY_PAID
  PAID
  WRITTEN_OFF
}

model Receivable {
  id          String   @id @default(cuid())
  workspaceId String
  teamId      String?

  partnerId           String?
  partnerNameSnapshot String

  title String

  // 정책 4-A: 단일 Receivable 다중통화. KRW와 USD가 같이 있으면 행 2개.
  currencyCode String @default("KRW")
  amountMinor  Int

  periodYear  Int
  periodMonth Int
  dueDate     DateTime?
  dueNote     String?

  status ReceivableStatus @default(OPEN)
  memo   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team      TourTeam? @relation(fields: [teamId], references: [id], onDelete: SetNull)
  partner   Partner?  @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  payments  ReceivablePayment[]

  @@index([workspaceId, status, dueDate])
  @@index([workspaceId, partnerId])
  @@index([workspaceId, periodYear, periodMonth])
  @@map("receivables")
}

model ReceivablePayment {
  id           String   @id @default(cuid())
  workspaceId  String
  receivableId String

  // Receivable과 같은 통화 권장 (다른 통화 입금 시 환전 후 입금으로 표현)
  currencyCode String
  amountMinor  Int
  paidAt       DateTime
  note         String?

  createdAt DateTime @default(now())

  workspace  Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  receivable Receivable @relation(fields: [receivableId], references: [id], onDelete: Cascade)

  @@index([workspaceId, receivableId])
  @@map("receivable_payments")
}

enum ExpenseStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PAID
}

model Expense {
  id          String   @id @default(cuid())
  workspaceId String
  teamId      String?

  title       String
  category    String?
  expenseDate DateTime

  currencyCode String @default("KRW")
  amountMinor  Int
  vatMinor     Int    @default(0)

  vendorName String?

  status       ExpenseStatus @default(DRAFT)
  approvedAt   DateTime?
  approvedById String?
  memo         String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  deletedAt   DateTime?

  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team        TourTeam?           @relation(fields: [teamId], references: [id], onDelete: SetNull)
  attachments ExpenseAttachment[]

  @@index([workspaceId, status, expenseDate])
  @@map("expenses")
}

model ExpenseAttachment {
  id          String   @id @default(cuid())
  workspaceId String
  expenseId   String

  fileName String
  fileUrl  String
  fileSize Int?
  mimeType String?

  // OCR 결과 (Phase 4 Hermes AI에서 채움)
  ocrStatus String? // PENDING/RUNNING/DONE/FAILED
  ocrJson   Json?

  createdAt DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  expense   Expense   @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([workspaceId, expenseId])
  @@map("expense_attachments")
}

// ─────────────────────────────────────────────────────────────────────────
// 분석 (Analytics) — 외부 sync 없음 (정책 5-A). 환율 등 시스템 자료만.
// ─────────────────────────────────────────────────────────────────────────

model ExchangeRate {
  id          String   @id @default(cuid())
  workspaceId String?  // null = 전역 기본 (시스템 캐시), 워크스페이스 전용 환율도 가능

  baseCurrency  String   @default("USD")
  quoteCurrency String   @default("KRW")
  rate          Float
  effectiveDate DateTime
  source        String?  // "manual" | "external_api" | "...".

  createdAt DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, baseCurrency, effectiveDate])
  @@map("exchange_rates")
}

// ═════════════════════════════════════════════════════════════════════════
// Phase 4 — 외부 통합 (Hermes AI / 카카오 알림톡 / 백업)
// Codex 08-phase4-integration-panels.md 명세 + 결정 사항 반영:
//   - BYO API 키 모델 (워크스페이스가 자체 OpenAI/Gemini/Anthropic 키 등록)
//   - Primary + Fallback (각 워크스페이스 1쌍)
//   - AES-GCM envelope encryption (워크스페이스별 DEK + 시스템 KEK)
//   - keyVersion snapshot — AiJob에 적용 비율 기록 (감사·재현)
//   - 카카오는 구현만, Phase 4 초반 활성화 차단
//   - 백업은 Neon PITR 자동 + 수동 export
// ═════════════════════════════════════════════════════════════════════════

enum IntegrationProvider {
  OPENAI
  GEMINI
  ANTHROPIC
}

enum AiProviderRole {
  PRIMARY
  FALLBACK
}

enum ConnectionTestStatus {
  NOT_TESTED
  SUCCESS
  FAILED
}

enum AiJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
  CANCELLED_KEY_ROTATED // 사용자가 "기존 키 즉시 폐기" 선택 시
}

enum ReceiptOcrJobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum MessagingProvider {
  KAKAO_ALIMTALK
  // ZALO, WECHAT 등은 Phase 5 이후
}

enum MessagingTemplateSyncStatus {
  DISABLED
  READY
  ERROR
}

enum BackupExportFormat {
  XLSX
  JSON
}

enum BackupExportStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum BackupExportTrigger {
  MANUAL  // 사용자가 직접 클릭
  CRON    // Phase 5: Vercel Cron 자동 일별
}

enum SettlementPdfStatus {
  GENERATING
  SUCCESS
  FAILED
}

enum SettlementPdfType {
  GUIDE
  PARTNER
  VEHICLE
  SHOPPING
  RECEIVABLE
}

enum MonthlyInsightStatus {
  GENERATING
  SUCCESS
  FAILED
}

// ─────────────────────────────────────────────────────────────────────────
// AI 통합 설정
// ─────────────────────────────────────────────────────────────────────────

model WorkspaceAiSettings {
  workspaceId String  @id
  enabled     Boolean @default(false)

  // 활성화 시점 + 마지막 연결 테스트 결과 캐시
  enabledAt         DateTime?
  lastTestedAt      DateTime?
  lastTestStatus    ConnectionTestStatus @default(NOT_TESTED)
  lastTestProvider  IntegrationProvider?
  lastTestMessage   String?
  lastTestLatencyMs Int?

  // 시스템 크레딧 폴백 허용 (둘 다 실패 시 시스템 키로 호출 + AiCredit 차감)
  allowSystemCreditFallback Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_ai_settings")
}

/// Primary/Fallback provider 별로 분리된 row.
/// 워크스페이스당 role(PRIMARY/FALLBACK) 각 1개 unique.
/// API 키는 AES-GCM으로 암호화: encryptedDek는 시스템 KEK로, apiKeyCiphertext는 DEK로 암호화.
model WorkspaceAiProviderConfig {
  id          String         @id @default(cuid())
  workspaceId String
  role        AiProviderRole

  provider  IntegrationProvider
  modelName String  // 자유 입력 (gpt-codex-auth-5.5, gemini-2.5-flash 등)

  // Envelope encryption
  apiKeyCiphertext Bytes
  apiKeyIv         Bytes
  apiKeyAuthTag    Bytes
  encryptedDek     Bytes
  dekKeyVersion    Int    @default(1) // 시스템 KEK 버전 (KEK 회전 대비)

  apiKeyMasked  String // "sk-***...****1234" 표시용
  apiKeyVersion Int    @default(1) // 키 변경마다 +1 (AiJob snapshot용)
  keyUpdatedAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, role])
  @@index([workspaceId, provider])
  @@map("workspace_ai_provider_configs")
}

/// AI 작업 단위. keyVersion snapshot으로 키 변경 중에도 진행 중 작업 안전.
model AiJob {
  id          String      @id @default(cuid())
  workspaceId String
  agentKind   AiAgentKind

  // 작업 생성 시점의 provider/model/keyVersion snapshot — 감사·재현
  providerSnapshot      IntegrationProvider
  modelSnapshot         String
  apiKeyVersionSnapshot Int
  roleSnapshot          AiProviderRole // PRIMARY로 시작했는지 FALLBACK이었는지

  // 작업 입력/출력 (큰 payload는 별도 저장 권장 — 여기는 메타만)
  refType     String? // "Expense", "GuideSettlement", "Receivable" 등
  refId       String?
  inputSummary  String? // 짧은 요약 (감사용, 원문은 저장 X)
  outputSummary String?

  status     AiJobStatus @default(QUEUED)
  startedAt  DateTime?
  finishedAt DateTime?
  durationMs Int?
  errorCode  String?
  errorMessage String?

  // AI 크레딧 차감 추적 (시스템 크레딧 모드 전용)
  systemCreditUsed Int @default(0)

  createdAt DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, agentKind, createdAt])
  @@index([workspaceId, status, createdAt])
  @@map("ai_jobs")
}

/// 영수증 사진 1장 OCR 작업.
/// AiJob보다 원본 이미지/추출 JSON/Expense 연결 필드가 많아 별도 모델로 분리한다.
model ReceiptOcrJob {
  id          String              @id @default(cuid())
  workspaceId String
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  imageMimeType String
  imageBase64   String            @db.Text
  imageBytes    Int

  provider   IntegrationProvider
  modelName  String
  keyVersion Int
  status     ReceiptOcrJobStatus  @default(PENDING)

  extractedData Json?
  errorCode     String?
  errorMessage  String?
  latencyMs     Int?
  expenseId     String?

  createdById String
  createdBy   User                @relation(fields: [createdById], references: [id])
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("receipt_ocr_jobs")
}

// ─────────────────────────────────────────────────────────────────────────
// 메시징 (카카오 알림톡 — Phase 4 초반 활성화 차단)
// ─────────────────────────────────────────────────────────────────────────

model WorkspaceMessagingSettings {
  workspaceId String @id

  enabled  Boolean @default(false)
  provider MessagingProvider @default(KAKAO_ALIMTALK)

  // 발신 프로필 (암호화 저장)
  senderProfileKeyCiphertext Bytes?
  senderProfileKeyIv         Bytes?
  senderProfileKeyAuthTag    Bytes?
  senderProfileKeyEncryptedDek Bytes?
  senderProfileKeyDekKeyVersion Int @default(1)
  senderProfileKeyMasked     String?
  senderPhone                String?
  senderName                 String?

  templateSyncStatus MessagingTemplateSyncStatus @default(DISABLED)
  templateSyncedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_messaging_settings")
}

// ─────────────────────────────────────────────────────────────────────────
// 백업 (Neon PITR + 수동 export + Phase 5 자동 일별)
// ─────────────────────────────────────────────────────────────────────────

model WorkspaceBackupSettings {
  workspaceId String @id

  // Neon Postgres PITR (자동, Neon 자체 기능)
  neonPitrEnabled       Boolean @default(true) // Free tier에서도 7일 자동
  neonPitrRetentionDays Int     @default(7)

  // 자동 일별 export (Phase 5 — Vercel Cron + Vercel Blob)
  dailyBlobExportEnabled Boolean @default(false)
  dailyBlobExportTime    String  @default("03:00") // KST 기준 HH:MM
  dailyBlobRetentionDays Int     @default(30)

  // 마지막 수동 export
  lastManualExportAt     DateTime?
  lastManualExportFormat BackupExportFormat?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_backup_settings")
}

model BackupExportJob {
  id          String              @id @default(cuid())
  workspaceId String
  trigger     BackupExportTrigger
  format      BackupExportFormat
  status      BackupExportStatus  @default(QUEUED)

  // export 범위 (사용자 선택)
  scopeMasters     Boolean @default(true)
  scopeOperations  Boolean @default(true)
  scopeSettlements Boolean @default(true)
  scopeFinance     Boolean @default(true)
  scopeAudit       Boolean @default(false) // OWNER만 선택 가능

  // 결과물
  fileName       String?
  fileSizeBytes  Int?
  storageUrl     String? // Vercel Blob URL 또는 signed URL
  downloadExpiresAt DateTime? // 만료 시간 (보안)

  startedAt    DateTime?
  finishedAt   DateTime?
  durationMs   Int?
  errorMessage String?

  requestedById String?
  createdAt     DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, createdAt])
  @@index([workspaceId, trigger, createdAt])
  @@map("backup_export_jobs")
}

model SettlementPdfJob {
  id          String              @id @default(cuid())
  workspaceId String
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  type    SettlementPdfType
  status  SettlementPdfStatus     @default(GENERATING)
  guideId String?

  periodStart DateTime
  periodEnd   DateTime

  fileName      String
  fileSizeBytes Int?
  pageCount     Int?
  errorMessage  String?
  latencyMs     Int?

  createdById String
  createdBy   User                @relation(fields: [createdById], references: [id])
  createdAt   DateTime            @default(now())

  @@index([workspaceId, type, createdAt(sort: Desc)])
  @@index([workspaceId, guideId])
  @@map("settlement_pdf_jobs")
}

model MonthlyInsight {
  id          String               @id @default(cuid())
  workspaceId String
  workspace   Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  periodYear  Int
  periodMonth Int
  status      MonthlyInsightStatus @default(GENERATING)

  statisticsJson  Json?
  summaryMarkdown String?          @db.Text

  provider   IntegrationProvider?
  modelName  String?
  keyVersion Int?

  errorCode    String?
  errorMessage String?
  latencyMs    Int?

  createdById String
  createdBy   User                 @relation(fields: [createdById], references: [id])
  createdAt   DateTime             @default(now())

  @@index([workspaceId, periodYear, periodMonth])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("monthly_insights")
}
